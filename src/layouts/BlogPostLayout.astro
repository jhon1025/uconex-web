---
import BaseLayout from './BaseLayout.astro';

interface Props {
  frontmatter: {
    title: string;
    description?: string;
    pubDate?: string;
    author?: string;
    tags?: string[];
    image?: {
      url: string;
      alt: string;
    };
  };
}

const { frontmatter } = Astro.props;

function formatDate(dateStr?: string) {
  if (!dateStr) return '';
  return new Date(dateStr).toLocaleDateString('es-ES', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout title={frontmatter.title} description={frontmatter.description}>

  <!-- Hero del post -->
  <section class="post-hero" style={frontmatter.image ? `--hero-bg: url('${frontmatter.image.url}')` : ''}>
    <div class="post-hero-glow"></div>
    {frontmatter.image && (
      <div class="post-hero-image">
        <img src={frontmatter.image.url} alt={frontmatter.image.alt} />
      </div>
    )}
    <div class="container post-hero-container">
      <a href="/blog" class="back-link">← Volver al blog</a>
      <div class="post-meta">
        {frontmatter.tags && frontmatter.tags.map((tag) => (
          <span class="post-tag">{tag}</span>
        ))}
        {frontmatter.pubDate && (
          <time class="post-date">{formatDate(frontmatter.pubDate)}</time>
        )}
      </div>
      <h1 class="post-title">{frontmatter.title}</h1>
      {frontmatter.description && (
        <p class="post-description">{frontmatter.description}</p>
      )}
      {frontmatter.author && (
        <div class="post-author">
          <span class="author-avatar">{frontmatter.author.charAt(0)}</span>
          <span>{frontmatter.author}</span>
        </div>
      )}
    </div>
  </section>

  <!-- Contenido del post -->
  <article class="post-body">
    <div class="container post-content-container">
      <div class="prose">
        <slot />
      </div>
    </div>
  </article>

</BaseLayout>

<style>
  /* ── Hero ── */
  .post-hero {
    position: relative;
    overflow: hidden;
    background: #06060f;
    margin-top: -68px;
    padding: calc(68px + 3rem) 0 3.5rem;
  }

  .post-hero-glow {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 700px;
    height: 400px;
    background: radial-gradient(ellipse at top, rgba(109, 40, 217, 0.2) 0%, transparent 70%);
    pointer-events: none;
  }

  .post-hero-image {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .post-hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.18;
  }

  .post-hero-container {
    position: relative;
    z-index: 1;
    max-width: 800px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.85rem;
    color: #a78bfa;
    text-decoration: none;
    margin-bottom: 1.5rem;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: #c4b5fd;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .post-tag {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #a78bfa;
    background: rgba(124, 58, 237, 0.12);
    border: 1px solid rgba(124, 58, 237, 0.3);
    border-radius: 999px;
    padding: 0.2rem 0.65rem;
  }

  .post-date {
    font-size: 0.8rem;
    color: #555;
  }

  .post-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    line-height: 1.2;
    color: #fff;
    margin-bottom: 1rem;
  }

  .post-description {
    font-size: 1.1rem;
    color: #a3a3a3;
    line-height: 1.7;
    max-width: 680px;
    margin-bottom: 1.5rem;
  }

  .post-author {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.875rem;
    color: #a3a3a3;
  }

  .author-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--purple);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  /* ── Cuerpo del artículo ── */
  .post-body {
    background: var(--bg-primary);
    padding: 3rem 0 5rem;
  }

  .post-content-container {
    max-width: 800px;
  }

  /* ── Prose (markdown) ── */
  .prose {
    color: #d1d5db;
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .prose h2 {
    font-size: 1.6rem;
    font-weight: 700;
    color: #fff;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #1e1e2e;
  }

  .prose h3 {
    font-size: 1.2rem;
    font-weight: 600;
    color: #e5e7eb;
    margin-top: 1.75rem;
    margin-bottom: 0.75rem;
  }

  .prose h4 {
    font-size: 1rem;
    font-weight: 600;
    color: #d1d5db;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .prose p {
    color: #d1d5db;
    margin-bottom: 1.25rem;
  }

  .prose strong {
    color: #fff;
    font-weight: 600;
  }

  .prose em {
    color: #a78bfa;
    font-style: italic;
  }

  .prose a {
    color: #a78bfa;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s;
  }

  .prose a:hover {
    color: #c4b5fd;
  }

  .prose ul,
  .prose ol {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .prose li {
    color: #d1d5db;
    margin-bottom: 0.5rem;
  }

  .prose li::marker {
    color: #7c3aed;
  }

  .prose blockquote {
    border-left: 3px solid #7c3aed;
    padding: 1rem 1.25rem;
    margin: 1.75rem 0;
    background: rgba(124, 58, 237, 0.06);
    border-radius: 0 0.5rem 0.5rem 0;
    color: #c4b5fd;
    font-style: italic;
  }

  .prose code {
    font-family: 'Fira Code', 'Courier New', monospace;
    font-size: 0.9em;
    background: #1e1e2e;
    color: #a78bfa;
    padding: 0.15em 0.4em;
    border-radius: 0.25rem;
  }

  .prose pre {
    background: #0c0c18;
    border: 1px solid #1e1e2e;
    border-radius: 0.75rem;
    padding: 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .prose pre code {
    background: none;
    padding: 0;
    color: #e2e8f0;
  }

  .prose hr {
    border: none;
    border-top: 1px solid #1e1e2e;
    margin: 2.5rem 0;
  }

  .prose img {
    width: 100%;
    border-radius: 0.75rem;
    margin: 2rem 0;
    border: 1px solid #1e1e2e;
  }

  .prose table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
  }

  .prose th {
    background: #0c0c18;
    color: #a78bfa;
    font-weight: 600;
    padding: 0.75rem 1rem;
    border: 1px solid #1e1e2e;
    text-align: left;
  }

  .prose td {
    padding: 0.6rem 1rem;
    border: 1px solid #1e1e2e;
    color: #d1d5db;
  }

  .prose tr:nth-child(even) td {
    background: rgba(124, 58, 237, 0.04);
  }
</style>
