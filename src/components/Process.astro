---
const pasos = [
  {
    num: '01',
    titulo: 'Diagnóstico gratuito',
    descripcion: 'Analizamos tu negocio, tu mercado y tus oportunidades digitales. Identificamos dónde estás perdiendo clientes.',
  },
  {
    num: '02',
    titulo: 'Estrategia personalizada',
    descripcion: 'Diseñamos un plan de marketing digital, automatización y desarrollo web adaptado a tu presupuesto.',
  },
  {
    num: '03',
    titulo: 'Implementación',
    descripcion: 'Activamos campañas, construimos tu sitio web y configuramos tus automatizaciones.',
  },
  {
    num: '04',
    titulo: 'Optimización continua',
    descripcion: 'Medimos resultados cada semana, ajustamos campañas y escalamos lo que funciona.',
  },
];
---

<section class="proceso" id="proceso">
  <div class="container">

    <!-- Encabezado -->
    <div class="proceso-header">
      <span class="proceso-label">Cómo funciona</span>
      <h2>Del primer contacto a clientes recurrentes en 4 pasos</h2>
      <p>Un proceso simple, transparente y enfocado en resultados desde el día uno.</p>
    </div>

    <!-- Timeline -->
    <div class="steps-wrapper">
      <!-- Línea conectora (solo desktop) -->
      <div class="connector" aria-hidden="true"></div>

      <ol class="steps">
        {pasos.map((paso) => (
          <li class="step">
            <div class="step-num-wrap">
              <div class="step-num">{paso.num}</div>
            </div>
            <div class="step-body">
              <h3>{paso.titulo}</h3>
              <p>{paso.descripcion}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>

  </div>
</section>

<style>
  /* ── Sección ────────────────────────────────────────────────────────────── */
  .proceso {
    background: #fafafa;
    padding: 6rem 1.5rem;
    border-top: 1px solid #ececec;
    border-bottom: 1px solid #ececec;
  }

  /* ── Encabezado ─────────────────────────────────────────────────────────── */
  .proceso-header {
    text-align: center;
    max-width: 560px;
    margin: 0 auto 4rem;
  }

  .proceso-label {
    display: inline-block;
    font-family: 'Graphie', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #7148FC;
    background: rgba(113, 72, 252, 0.07);
    border: 1px solid rgba(113, 72, 252, 0.18);
    border-radius: 4px;
    padding: 0.25rem 0.65rem;
    margin-bottom: 1rem;
  }

  .proceso-header h2 {
    font-family: 'Avant Garde', sans-serif;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #161616;
    line-height: 1.2;
    margin-bottom: 0.85rem;
  }

  .proceso-header p {
    font-family: 'Graphie', sans-serif;
    font-size: 0.95rem;
    line-height: 1.7;
    color: #6b6b76;
  }

  /* ── Wrapper posicionado ────────────────────────────────────────────────── */
  .steps-wrapper {
    position: relative;
  }

  /* ── Línea conectora horizontal ─────────────────────────────────────────── */
  .connector {
    display: none; /* oculta en móvil, visible en desktop */
  }

  /* ── Lista de pasos ─────────────────────────────────────────────────────── */
  .steps {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    position: relative;
    z-index: 1;
  }

  /* ── Paso individual ────────────────────────────────────────────────────── */
  .step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  /* Círculo con número */
  .step-num-wrap {
    margin-bottom: 1.25rem;
    position: relative;
    z-index: 2;
  }

  .step-num {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: #161616;
    color: #fff;
    font-family: 'Avant Garde', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    letter-spacing: 0.02em;
    transition: background 0.25s ease, box-shadow 0.25s ease;
  }

  .step:hover .step-num {
    background: #4924BC;
    box-shadow: 0 0 0 6px rgba(113, 72, 252, 0.12);
  }

  /* Texto */
  .step-body h3 {
    font-family: 'Avant Garde', sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    color: #161616;
    margin-bottom: 0.5rem;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .step-body p {
    font-family: 'Graphie', sans-serif;
    font-size: 0.85rem;
    line-height: 1.65;
    color: #6b6b76;
    max-width: 220px;
    margin: 0 auto;
  }

  /* ── Desktop: línea conectora entre círculos ────────────────────────────── */
  @media (min-width: 769px) {
    .connector {
      display: block;
      position: absolute;
      top: 30px; /* mitad del círculo 60px */
      left: calc(12.5% + 30px);  /* centro del primer círculo */
      right: calc(12.5% + 30px); /* centro del último círculo */
      height: 1px;
      border-top: 2px dashed #d1d1d6;
      z-index: 0;
    }
  }

  /* ── Responsive: vertical en móvil ─────────────────────────────────────── */
  @media (max-width: 768px) {
    .proceso {
      padding: 4rem 1.25rem;
    }

    .steps {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .step {
      flex-direction: row;
      text-align: left;
      align-items: flex-start;
      gap: 1.25rem;
      padding: 1.5rem 0;
      border-bottom: 1px solid #ececec;
      position: relative;
    }

    .step:last-child {
      border-bottom: none;
    }

    /* Línea vertical conectora en móvil */
    .step:not(:last-child)::after {
      content: '';
      position: absolute;
      left: 29px; /* centro del círculo 60px */
      top: calc(1.5rem + 60px);
      bottom: 0;
      width: 2px;
      background: repeating-linear-gradient(
        to bottom,
        #d1d1d6 0px,
        #d1d1d6 6px,
        transparent 6px,
        transparent 12px
      );
    }

    .step-num-wrap {
      margin-bottom: 0;
      flex-shrink: 0;
    }

    .step-body p {
      max-width: none;
      margin: 0;
    }
  }

  @media (max-width: 480px) {
    .step-num {
      width: 52px;
      height: 52px;
      font-size: 1rem;
    }

    .step:not(:last-child)::after {
      left: 25px;
    }
  }
</style>
