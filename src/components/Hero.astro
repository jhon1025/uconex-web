---

<section class="hero">
  <div class="hero-content">

    <!-- Logo -->
    <div class="hero-logo">
      <img src="/IMAGOTIPO%20GRANDE%201%20uconex.svg" alt="Uconex" class="hero-logo-img" />
    </div>

    <!-- Título -->
    <h1 class="hero-title">
      Escalamos tu negocio<br />
      con marketing e<br />
      <span class="hero-highlight">Inteligencia Artificial</span>
    </h1>

    <!-- Subtítulo -->
    <p class="hero-subtitle">
      ¿Quieres llegar a tus objetivos de ventas? Nosotros escalamos, diversificamos y
      automatizamos tus ventas. <strong>Somos tu partner en crecimiento exponencial</strong>
    </p>

    <!-- Tags -->
    <div class="hero-tags">
      <span class="hero-tag">Pauta digital</span>
      <span class="hero-tag">Desarrollo web</span>
      <span class="hero-tag">Automatización</span>
    </div>

    <!-- CTAs -->
    <div class="hero-ctas">
      <a href="#contacto" class="btn-primary">Contáctanos</a>
      <a href="#servicios" class="btn-secondary">
        Ver soluciones
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<style>
  /* ── Sección hero ─────────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    width: 100%;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #0a0a0f;
    /* extiende detrás del navbar glassmorphism */
    margin-top: -68px;
    padding: calc(68px + 2rem) 1.5rem 2rem;
  }

  /* ── Grid pattern via ::before ────────────────────────────────────────────── */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background-image:
      linear-gradient(
        0deg,
        transparent 24%,
        rgba(255,255,255,0.06) 25%,
        rgba(255,255,255,0.06) 26%,
        transparent 27%,
        transparent 74%,
        rgba(255,255,255,0.06) 75%,
        rgba(255,255,255,0.06) 76%,
        transparent 77%,
        transparent
      ),
      linear-gradient(
        90deg,
        transparent 24%,
        rgba(255,255,255,0.06) 25%,
        rgba(255,255,255,0.06) 26%,
        transparent 27%,
        transparent 74%,
        rgba(255,255,255,0.06) 75%,
        rgba(255,255,255,0.06) 76%,
        transparent 77%,
        transparent
      );
    background-size: 60px 60px;
    -webkit-mask-image: linear-gradient(to bottom, black 0%, rgba(0,0,0,0.7) 30%, rgba(0,0,0,0.3) 50%, transparent 70%);
    mask-image:         linear-gradient(to bottom, black 0%, rgba(0,0,0,0.7) 30%, rgba(0,0,0,0.3) 50%, transparent 70%);
    pointer-events: none;
  }

  /* ── Glow morado via ::after ──────────────────────────────────────────────── */
  .hero::after {
    content: '';
    position: absolute;
    bottom: -20%;
    left: 50%;
    transform: translateX(-50%);
    width: 80%;
    height: 60%;
    background: radial-gradient(
      ellipse at center,
      rgba(113, 72, 252, 0.4)  0%,
      rgba(113, 72, 252, 0.15) 30%,
      rgba(113, 72, 252, 0.05) 50%,
      transparent 70%
    );
    z-index: 1;
    filter: blur(40px);
    pointer-events: none;
  }

  /* ── Contenido ────────────────────────────────────────────────────────────── */
  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 820px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Logo */
  .hero-logo {
    margin-bottom: 1.75rem;
  }

  .hero-logo-img {
    height: 46px;
    width: auto;
    display: block;
  }

  /* Título */
  .hero-title {
    font-family: 'Avant Garde', sans-serif;
    font-size: clamp(2.2rem, 5.5vw, 3.8rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #fff;
    margin-bottom: 1.5rem;
  }

  /* Badge gradiente de marca */
  .hero-highlight {
    display: inline-block;
    background: linear-gradient(135deg, #4924BC 0%, #7148FC 50%, #9D8CF4 100%);
    padding: 0.2em 0.75em;
    border-radius: 12px;
    box-shadow:
      0 0 30px rgba(113, 72, 252, 0.35),
      0 0 60px rgba(113, 72, 252, 0.15),
      inset 0 1px 0 rgba(255, 255, 255, 0.15);
    line-height: inherit;
  }

  /* Subtítulo */
  .hero-subtitle {
    font-family: 'Graphie', sans-serif;
    font-size: clamp(0.9rem, 1.8vw, 1.05rem);
    font-weight: 400;
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.75;
    max-width: 600px;
    margin-bottom: 1.75rem;
  }

  .hero-subtitle strong {
    color: #fff;
    font-weight: 600;
  }

  /* Tags */
  .hero-tags {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-bottom: 2rem;
  }

  .hero-tag {
    font-family: 'Graphie', sans-serif;
    font-size: 0.85rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.7);
    padding: 0.4em 1.2em;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 50px;
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    transition: all 0.3s ease;
    cursor: default;
  }

  .hero-tag:hover {
    border-color: #9D8CF4;
    color: #fff;
    background: rgba(113, 72, 252, 0.1);
  }

  /* CTAs */
  .hero-ctas {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .btn-primary,
  .btn-secondary {
    font-family: 'Graphie', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    padding: 0.85em 2.2em;
    border-radius: 50px;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    white-space: nowrap;
  }

  /* Primario: blanco sólido → hueco al hover */
  .btn-primary {
    background: #fff;
    color: #0a0a0f;
    border: 2px solid #fff;
    box-shadow: 0 4px 20px rgba(255, 255, 255, 0.1);
  }

  .btn-primary:hover {
    background: transparent;
    color: #fff;
    box-shadow: 0 4px 30px rgba(255, 255, 255, 0.15);
    transform: translateY(-2px);
  }

  /* Secundario: outline sutil → purple al hover */
  .btn-secondary {
    background: transparent;
    color: #fff;
    border: 2px solid rgba(255, 255, 255, 0.2);
  }

  .btn-secondary:hover {
    border-color: #9D8CF4;
    background: rgba(113, 72, 252, 0.1);
    transform: translateY(-2px);
  }

  /* ── Responsive 768px ─────────────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .hero {
      min-height: 100svh;
      padding: calc(68px + 1.5rem) 1rem 2rem;
    }

    .hero::before {
      background-size: 45px 45px;
    }

    .hero-ctas {
      flex-direction: column;
      align-items: center;
      width: 100%;
    }

    .btn-primary,
    .btn-secondary {
      width: 100%;
      max-width: 280px;
      justify-content: center;
    }
  }

  /* ── Responsive 480px ─────────────────────────────────────────────────────── */
  @media (max-width: 480px) {
    .hero::before {
      background-size: 35px 35px;
    }

    .hero-title {
      font-size: clamp(1.8rem, 8vw, 2.5rem);
    }

    .hero-highlight {
      font-size: 0.9em;
      padding: 0.2em 0.6em;
      border-radius: 8px;
    }

    .hero-subtitle {
      font-size: 0.9rem;
    }

    .hero-tag {
      font-size: 0.78rem;
      padding: 0.35em 1em;
    }
  }
</style>
